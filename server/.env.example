# Backend server port
PORT=5000

# MongoDB Connection String (e.g., MongoDB Atlas or local MongoDB)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/taskmanager

# JSON Web Token (JWT) secret key for authentication security
JWT_SECRET=your_jwt_secret_key_here

# Gmail credentials for sending OTP & due date reminders
# Note: EMAIL_PASS must be a Google App Password, not your standard Gmail password.
EMAIL_USER=your_gmail_address@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# URL of the client frontend for CORS and Socket.io verification
CLIENT_URL=http://localhost:3000
# Production: https://to-do-task-dusky-alpha.vercel.app

# Optional password for the shared guest account (defaults to guest-demo-password-2024)
GUEST_PASSWORD=guest-demo-password-2024
